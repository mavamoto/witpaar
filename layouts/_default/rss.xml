{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ with .Params.feedTitle }}{{ . }}{{ else }}{{ .Site.Title }}{{ end }}</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>{{ .Site.Params.description | htmlEscape }}</description>
    <language>{{ .Site.Language.Locale }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />

    {{ range first 20 .RegularPages }}
    <item>
      <title>{{ .Title | htmlEscape }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Content | plainify | truncate 300 | htmlEscape }} ... <a href="{{ .Permalink }}">Leer más</a></description>
    </item>
    {{ end }}
  </channel>
</rss>

